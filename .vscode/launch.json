{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder:pomo-tank}",
        "${workspaceFolder:pomo-tank}"
      ],
      "outFiles": ["${workspaceFolder:pomo-tank}/dist/**/*.js"],
      "preLaunchTask": "npm: watch"
    }
  ]
}
